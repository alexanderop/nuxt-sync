{
  "name": "nuxt-sync",
  "version": "0.1.0",
  "description": "Real-time collaborative data for Nuxt — independent CRDTs with Nitro WebSocket sync",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    },
    "./schema": {
      "types": "./dist/runtime/core/schema.d.ts",
      "import": "./dist/runtime/core/schema.mjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "build": "nuxt-module-build build",
    "prepare": "nuxi prepare playground",
    "typecheck": "nuxi typecheck playground",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:composables": "vitest --project composables",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest && playwright test",
    "test:coverage": "vitest --coverage",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix"
  },
  "dependencies": {
    "@nuxt/kit": "^3.16.0",
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.4",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "fast-check": "^4.6.0",
    "jsdom": "^28.1.0",
    "nuxt": "^3.16.0",
    "oxlint": "^1.52.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "nuxt": "^3.16.0"
  }
}
